generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ChannelType {
  WEBSITE
  WHATSAPP
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  phone     String?
  email     String?
  website   String?
  address   String?
  openingTime String?
  closingTime String?
  admissionProcess String?
  documentsRequired String?
  greetingMessage String?
  onboardingComplete Boolean @default(false)
  workingDays       String?  @default("[1,2,3,4,5,6]")
  maxBookingsPerSlot Int     @default(1)
  appointmentDuration Int    @default(60)
  widgetPrimaryColor String? @default("#7C3AED")
  widgetDarkMode    Boolean  @default(false)
  whatsappPhoneNumberId String?
  whatsappBusinessAccountId String?
  whatsappApiToken    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  subscriptions  Subscription[]
  courses        Course[]
  faqs           FAQ[]
  knowledgeBases KnowledgeBase[]
  embeddings     Embedding[]
  conversations  Conversation[]
  leads          Lead[]
  appointments   Appointment[]
  followUpRules  FollowUpRule[]
  followUpLogs   FollowUpLog[]
  campaigns      Campaign[]
}

model User {
  id        String   @id
  email     String   @unique
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  leadNotes            LeadNote[]
  assignedConversations Conversation[] @relation("AssignedConversations")
}

model Membership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role     @default(STAFF)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  status                 SubscriptionStatus @default(INACTIVE)
  plan                   String             @default("free")
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Course {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  duration       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fees         Fee[]

  @@index([organizationId])
}

model Fee {
  id       String @id @default(cuid())
  courseId String
  amount   Int
  discount Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model FAQ {
  id             String   @id @default(cuid())
  organizationId String
  question       String
  answer         String
  category       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, category])
}

model KnowledgeBase {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  content        String
  category       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, category])
}

model Embedding {
  id             String   @id @default(cuid())
  organizationId String
  sourceType     String
  sourceId       String
  content        String
  vector         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([organizationId])
}

model Lead {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  phone            String?
  email            String?
  interestedCourse String?
  source           String   @default("direct")
  status           String   @default("new")
  score            Int      @default(0)
  category         String   @default("cold")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notes        LeadNote[]
  activities   LeadActivity[]
  appointments Appointment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, score])
  @@index([organizationId, name])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  content   String
  authorId  String
  createdAt DateTime @default(now())

  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([leadId])
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([leadId, type])
}

model Appointment {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  leadName       String
  leadPhone      String?
  leadEmail      String?
  date           DateTime
  time           String
  status         String   @default("pending")
  notes          String?
  cancelledAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, date])
  @@index([organizationId, status])
  @@index([organizationId, date, time])
}

model FollowUpRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  trigger        String   // "no_response", "lead_not_converted"
  delayHours     Int
  channel        String   @default("WHATSAPP")
  template       String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUpLogs  FollowUpLog[]

  @@index([organizationId])
  @@index([organizationId, enabled])
}

model FollowUpLog {
  id             String       @id @default(cuid())
  organizationId String
  conversationId String
  ruleId         String
  scheduledAt    DateTime
  sentAt         DateTime?
  status         String       // "scheduled", "sent", "failed", "cancelled"
  error          String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  rule         FollowUpRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([scheduledAt])
}

model Conversation {
  id             String      @id @default(cuid())
  organizationId String
  channel        ChannelType @default(WEBSITE)
  channelId      String?
  studentName    String?
  parentName     String?
  phone          String?
  email          String?
  classField     String?     @map("class")
  targetExam     String?
  language       String      @default("english")
  status         String      @default("active")
  mode           String      @default("auto")
  assignedToId   String?
  assignedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]
  assignedTo   User?        @relation("AssignedConversations", fields: [assignedToId], references: [id])
  followUpLogs FollowUpLog[]

  @@index([organizationId])
  @@index([organizationId, channel])
  @@index([organizationId, status])
  @@index([organizationId, channel, status])
  @@index([assignedToId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  channel        ChannelType @default(WEBSITE)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, channel])
  @@index([conversationId, createdAt])
}

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  headline       String?
  subtitle       String?
  ctaText        String   @default("Submit")
  buttonColor    String   @default("#7C3AED")
  fields         Json     @default("[\"name\",\"phone\",\"email\",\"course\"]")
  isActive       Boolean  @default(true)
  viewCount      Int      @default(0)
  submissionCount Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  CampaignSubmission[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model CampaignSubmission {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  phone      String?
  email      String?
  course     String?
  leadId     String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, createdAt])
}
